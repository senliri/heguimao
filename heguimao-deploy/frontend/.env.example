# Cloudflare Worker URL（生产环境指向 Worker）
VITE_WORKER_URL=https://heguimao-api.senliri028.workers.dev

# AI API 配置（仅 dev 模式直连使用）
VITE_AGNES_API_KEY=your_api_key_here
VITE_AGNES_MODEL=agnes-2.0-flash

# 应用访问密码（生产必须设置）
AUTH_PASSWORD=your_secure_password_here

# 邮件 SMTP 配置（生产 Cloudflare Pages 不支持 Node.js functions，需改用 Worker 处理）
# SMTP_USER=senlin2027@126.com
# SMTP_PASS=your_126_auth_code

# 生产部署注意事项：
# 1. Demo 用户：VITE_DEMO_ENABLED=false 禁用（默认已禁用）
# 2. 如需自定义 demo 用户：设置 VITE_DEMO_EMAIL / VITE_DEMO_PASSWORD
# 3. 设置 AUTH_PASSWORD 为强密码
# 4. 配置 SMTP 用于密码重置
# 5. 所有敏感配置通过 Vercel 环境变量设置，不要提交 .env 文件
