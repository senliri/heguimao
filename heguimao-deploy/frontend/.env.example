# ⚠️ Vercel 和 Worker 之前都停用过，现已恢复 Worker
# 架构：前端(Cloudflare Pages) → Worker 代理 → Agnes API
# Worker 隐藏 API key，前端无需暴露密钥

# Cloudflare Worker URL（AI 请求代理）
VITE_WORKER_URL=https://heguimao-api.senliri028.workers.dev/api/chat

# AI API 配置
VITE_AGNES_MODEL=agnes-2.0-flash

# 应用访问密码（生产必须设置）
AUTH_PASSWORD=your_secure_password_here

# 邮件 SMTP 配置（生产 Cloudflare Pages 不支持 Node.js functions，需改用 Worker 处理）
# SMTP_USER=senlin2027@126.com
# SMTP_PASS=your_126_auth_code

# 生产部署注意事项：
# 1. Demo 用户：VITE_DEMO_ENABLED=false 禁用（默认已禁用）
# 2. 如需自定义 demo 用户：设置 VITE_DEMO_EMAIL / VITE_DEMO_PASSWORD
# 3. 设置 AUTH_PASSWORD 为强密码
# 4. 配置 SMTP 用于密码重置
# 5. 所有敏感配置通过 Cloudflare Pages / Cloudflare Workers 环境变量设置
# 6. ⚠️ Worker 端需在 Cloudflare Dashboard 设置 AGNES_API_KEY 环境变量
# 7. 前端不需要 VITE_AGNES_API_KEY（key 由 Worker 代理处理）
