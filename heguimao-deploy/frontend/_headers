/*
  X-Robots-Tag: noindex

/assets/*.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/assets/*.css
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/translations/*
  Content-Type: application/json
  Cache-Control: public, max-age=31536000, immutable
